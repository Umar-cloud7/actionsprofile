# ============================================================
# terraform.tfvars — Your actual values go here
# ADD THIS FILE TO .gitignore — never commit passwords
# ============================================================

aws_region   = "ap-south-1"
project_name = "vprofile"
environment  = "dev"

# Network
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.3.0/24", "10.0.4.0/24"]

# Your IP for SSH — find it at https://whatismyip.com and add /32
your_ip = "47.11.42.23/32"   # REPLACE with your actual IP

# EC2
web_instance_type  = "t3.micro"
app_instance_type  = "t3.small"
cicd_instance_type = "t3.medium"
public_key_path    = "~/.ssh/id_rsa.pub"

# RDS
db_instance_class = "db.t3.micro"
db_name           = "accounts"
db_username       = "admin"
db_password       = "REPLACE_WITH_STRONG_PASSWORD"   # Min 8 chars
